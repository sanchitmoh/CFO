# ══════════════════════════════════════════════════════════════════
# AI CFO Backend - Environment Configuration
# ══════════════════════════════════════════════════════════════════
# 
# 🚨 SECURITY WARNING: Never commit this file with real credentials!
# 
# For production deployment, see backend/SECURITY.md for complete
# security configuration guide.
# ══════════════════════════════════════════════════════════════════

# ── Database ──
# Local default — override with your hosted Postgres DSN (Neon, Supabase, RDS, etc.)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aicfo

# ── Redis ──
# Local default — override with your hosted Redis DSN (Upstash, Elasticache, etc.)
# ⚠️  For Upstash: use the Redis protocol URL (rediss://), NOT the REST API URL (https://)
# Format: rediss://default:<UPSTASH_REST_TOKEN>@<HOST>.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# ── Clerk Auth ──
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# ── OpenAI ──
# 🚨 CRITICAL: Must be set for AI chat to work!
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── App ──
# 🚨 CRITICAL: Must override CORS_ORIGINS in production!
# Leaving localhost origins will BLOCK all frontend requests in production.
# Example production: CORS_ORIGINS=["https://app.yourdomain.com","https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
DEBUG=true

# ── Encryption (field-level) ──
# 🚨 CRITICAL: Required for encrypting sensitive data (Plaid tokens, webhooks)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Example: WEBHOOK_ENCRYPTION_KEY=abc123def456...
WEBHOOK_ENCRYPTION_KEY=

# CRIT-004: Per-deployment KDF salt — REQUIRED when WEBHOOK_ENCRYPTION_KEY is a passphrase
# Generate with: python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# ⚠️  Each deployment MUST have a unique, random value — never share across environments
KEY_DERIVATION_SALT=

# ── Observability (OpenTelemetry — ADVANCE-001) ──
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ai-cfo-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# 🚨 SECURITY (HIGH-009): Use secure TLS connections in production
# Set to true ONLY for local development with unencrypted endpoints
# Production should use https:// endpoint with OTEL_INSECURE=false (default)
OTEL_INSECURE=false

# ── Plaid Banking (ADVANCE-003) ──
# Get credentials from: https://dashboard.plaid.com/
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_secret
PLAID_ENV=sandbox  # sandbox | development | production
PLAID_WEBHOOK_URL=https://yourdomain.com/api/plaid/webhook

# ── Embeddings (ADVANCE-005 — free local model) ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# ── File Uploads (FILE-001) ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── Forecast Model (L-004) ──
# "linear" = built-in linear regression (default, no extra deps)
# "prophet" = Meta Prophet time-series (requires: pip install prophet)
FORECAST_MODEL=linear

# ── Email Configuration ──
# Choose your email provider: sendgrid | aws_ses | smtp
EMAIL_PROVIDER=smtp

# SendGrid (Option 1 - Recommended for production)
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# AWS SES (Option 2 - Cost-effective for high volume)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# SMTP (Option 3 - Gmail, Outlook, or any SMTP server)
# For Gmail: Use App Password (not regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_USE_TLS=true

# Email sender details
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=AI CFO Platform

# ── Slack Configuration ──
# Enable Slack notifications
SLACK_ENABLED=false

# Incoming Webhook (Simple method - recommended for getting started)
# Create webhook at: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Bot Token (Advanced method - for interactive features)
# Get token from: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_DEFAULT_CHANNEL=#finance-alerts
SLACK_SIGNING_SECRET=your-signing-secret
